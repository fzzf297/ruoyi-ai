# Production environment template for internal network deployment.
# Copy to .env and replace all placeholder values before running docker compose.

# -----------------------------------------------------------------------------
# admin
# -----------------------------------------------------------------------------

# Random secret key for admin JWT signing.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_SECRET_KEY=change-me-to-a-random-secret

# Initial admin password. Change after first login.
ADMIN_API_DEFAULT_ADMIN_PASSWORD=change-me-to-a-strong-password

# -----------------------------------------------------------------------------
# agent
# -----------------------------------------------------------------------------

# Internal OpenAI-compatible LLM endpoint.
# Example: http://internal-llm.example.com:8000/v1
AGENT_LLM_BASE_URL=https://api.deepseek.com

# LLM API key. For internal LLM without auth, set a non-empty placeholder.
AGENT_LLM_API_KEY=change-me

# LLM model name.
AGENT_LLM_MODEL=deepseek-chat

# Rate limit: max session creations per IP per minute.
AGENT_RATE_LIMIT_PER_MINUTE=30

# Max recent messages kept in LLM context; older messages are summarized.
AGENT_MAX_SESSION_MESSAGES=100
