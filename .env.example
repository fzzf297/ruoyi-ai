# Monorepo backend selector
BACKEND_MODE=cloud

# Frontend
WEB_PORT=80
WEB_BASE_API=/dev-api

# Gateway
GATEWAY_URL=http://localhost:8080

# Nacos
NACOS_URL=http://localhost:8848/nacos
NACOS_NAMESPACE=dev
NACOS_GROUP=DEFAULT_GROUP

# Database examples only. Keep local secrets out of git.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=ry-cloud
MYSQL_ROOT_PASSWORD=change-me-for-local-dev

# Redis example only. Keep local secrets out of git.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me-for-local-dev

# Independent admin-api backend
ADMIN_API_ENV=local
ADMIN_API_PORT=8000
ADMIN_API_DATABASE_URL=sqlite:///data/admin-api.db
ADMIN_API_SECRET_KEY=change-me-for-local-dev
ADMIN_API_ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_API_REFRESH_TOKEN_EXPIRE_DAYS=7
ADMIN_API_LOGIN_MAX_ATTEMPTS=5
ADMIN_API_LOGIN_LOCK_MINUTES=15
ADMIN_API_CORS_ORIGINS=http://localhost:5173,http://localhost:80
ADMIN_API_DEFAULT_ADMIN_USERNAME=admin
ADMIN_API_DEFAULT_ADMIN_PASSWORD=admin123
ADMIN_API_DEFAULT_ADMIN_DISPLAY_NAME=Administrator
